{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#7FB4CA",
          "style": "plain",
          "properties": {
            "display_host": true
          },
          "template": "{{ .UserName }} on {{ .HostName }}",
          "type": "session"
        },
        {
          "foreground": "#7E9CD8",
          "style": "plain",
          "properties": {
            "time_format": "Monday at 3:04 PM"
          },
          "template": " {{ .CurrentDate | date .Format }} ",
          "type": "time"
        },
        {
          "foreground": "#957FB8",
          "style": "plain",
          "properties": {
            "branch_icon": "",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_worktree_count": true
          },
          "template": " branch: {{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} | changed: {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} staged: {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} | stashes: {{ .StashCount }}{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "#98BB6C",
          "style": "plain",
          "template": "",
          "type": "text"
        },
        {
          "foreground": "#98BB6C",
          "style": "plain",
          "properties": {
            "style": "dallas",
            "threshold": 0
          },
          "template": " {{ .FormattedMs }}s ",
          "type": "executiontime"
        },
        {
          "style": "plain",
          "properties": {
            "root_icon": "#"
          },
          "template": "{{ if .Root }} [root] {{ end }}",
          "type": "root"
        },
        {
          "foreground": "#7AA89F",
          "style": "plain",
          "template": " MEM: {{ round .PhysicalPercentUsed .Precision }}% ({{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB) ",
          "type": "sysinfo"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#C8C093",
          "style": "plain",
          "template": "+-",
          "type": "text"
        },
        {
          "foreground": "#C8C093",
          "style": "plain",
          "properties": {
            "folder_icon": "",
            "folder_separator_icon": " / ",
            "home_icon": "~",
            "style": "agnoster_full"
          },
          "template": " in {{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#98BB6C",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#E82424{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "{{ if gt .Code 0 }} [exit {{ .Code }}] {{ else }} $ {{ end }}",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{ .Folder }}",
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#C8C093",
    "template": "> "
  },
  "version": 3
}
