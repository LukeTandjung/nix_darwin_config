{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#7FB4CA",
          "properties": {
            "display_host": true
          },
          "style": "diamond",
          "template": "\uf007 {{ .UserName }} <#C8C093>on</> \uf108 {{ .HostName }}",
          "type": "session"
        },
        {
          "foreground": "#7E9CD8",
          "properties": {
            "time_format": "Monday <#C8C093>at</> 3:04 PM"
          },
          "style": "diamond",
          "template": " \uf017 {{ .CurrentDate | date .Format }} ",
          "type": "time"
        },
        {
          "foreground": "#957FB8",
          "properties": {
            "branch_icon": "\uf126 ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_worktree_count": true
          },
          "style": "diamond",
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \uf187 {{ .StashCount }}{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "foreground": "#98BB6C",
          "style": "plain",
          "type": "text",
          "template": ""
        },
        {
          "foreground": "#98BB6C",
          "properties": {
            "style": "dallas",
            "threshold": 0
          },
          "style": "diamond",
          "template": " {{ .FormattedMs }} <#C8C093>\uf2f2</>",
          "type": "executiontime"
        },
        {
          "properties": {
            "root_icon": "\uf292 "
          },
          "style": "diamond",
          "template": " \uf0e7 ",
          "type": "root"
        },
        {
          "foreground": "#7AA89F",
          "style": "diamond",
          "template": " <#C8C093>MEM:</> {{ round .PhysicalPercentUsed .Precision }}% ({{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB) \uf2db",
          "type": "sysinfo"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "#C8C093",
          "style": "plain",
          "template": "─",
          "type": "text"
        },
        {
          "foreground": "#7FB4CA",
          "properties": {
            "folder_icon": "\uf07b",
            "folder_separator_icon": " \uf061 ",
            "home_icon": "\uf015",
            "style": "agnoster_full"
          },
          "style": "diamond",
          "template": " \uf07b {{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "#98BB6C",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#E82424{{ end }}"
          ],
          "properties": {
            "always_enabled": true
          },
          "style": "plain",
          "template": " \uf105 ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "console_title_template": "{{ .Folder }}",
  "transient_prompt": {
    "background": "transparent",
    "foreground": "#C8C093",
    "template": "\uf105 "
  },
  "version": 3
}
